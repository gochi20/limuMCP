LIMU_DB_HOST=127.0.0.1
LIMU_DB_PORT=3306
LIMU_DB_NAME=limutradee
LIMU_DB_USER=root
LIMU_DB_PASSWORD=

# Optional for local XAMPP socket-based MySQL connections.
# LIMU_DB_SOCKET=/Applications/XAMPP/xamppfiles/var/mysql/mysql.sock

LIMU_DB_CONNECTION_LIMIT=5
LIMU_MCP_DEFAULT_LIMIT=25
LIMU_MCP_MAX_LIMIT=100

# Remote/Vercel MCP mode.
LIMU_PORTAL_BASE_URL=https://portal.limu.co.mw
LIMU_OAUTH_ISSUER=https://portal.limu.co.mw/Api/v1/oauth
LIMU_OAUTH_CLIENT_ID=limu-vercel-mcp
# Optional for confidential OAuth clients.
# LIMU_OAUTH_CLIENT_SECRET=
# Exact callback URL for the deployed Vercel MCP app or local OAuth test client.
LIMU_OAUTH_REDIRECT_URI=https://limu-mcp.vercel.app/api/auth/callback/limu

# Used only by `npm run register-oauth-client`; do not set these in Vercel.
# LIMU_ADMIN_TOKEN=
# LIMU_ADMIN_EMAIL=
# LIMU_ADMIN_PASSWORD=
